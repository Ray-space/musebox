# MiniMax — 图文理解(M3) + 开盒文案(M3) + 实时生曲(music-2.6)
# 申请: https://platform.minimaxi.com/
MINIMAX_API_KEY=
MINIMAX_API_BASE=https://api.minimaxi.com
MINIMAX_TEXT_MODEL=MiniMax-M3

# OpenAI — 可选 fallback（未配置时全程走 MiniMax）
# 申请: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# generate = 强制 AI 生曲（失败不回退曲库，推荐比赛 Demo）
# auto = 生曲失败回退曲库 | library = 仅曲库
MUSIC_MODE=generate
# 生曲超时毫秒：推荐 240000（4 分钟）；0 = 不限制
MUSIC_GENERATION_TIMEOUT_MS=240000
# 瞬时网络错误自动重试一次（默认开启，设为 0 关闭）
# MUSIC_GENERATION_RETRY=1

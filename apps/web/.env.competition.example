# 比赛 Demo 推荐环境变量（复制到 Vercel → Settings → Environment Variables）
# 密钥从本地 .env.local 读取，不要提交到 Git

MINIMAX_API_KEY=<从本地 .env.local 复制>
MINIMAX_API_BASE=https://api.minimaxi.com
MINIMAX_TEXT_MODEL=MiniMax-M3

# 比赛推荐：强制 AI 生曲，不回退空曲库
MUSIC_MODE=generate

# 比赛推荐：240 秒超时，给 MiniMax 足够生成时间
MUSIC_GENERATION_TIMEOUT_MS=240000

# 云托管必须异步（公网 HTTP 60 秒限制）；Vercel 可设为 0 走同步
OPEN_ASYNC=1

# 可选 fallback
# OPENAI_API_KEY=
